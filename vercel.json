{
  "functions": {
    "app/workflow/[id]/page.tsx": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://thinklyneo-backend.vercel.app/api/:path*"
    },
    {
      "source": "/docs",
      "destination": "https://thinkly-6b82c0dd.mintlify.dev/docs"
    },
    {
      "source": "/docs/:match*",
      "destination": "https://thinkly-6b82c0dd.mintlify.dev/docs/:match*"
    }
  ]
}
