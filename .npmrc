# Route @shashank519915-scoped packages to GitHub Packages.
# For CI: NODE_AUTH_TOKEN = secrets.GITHUB_TOKEN (injected by Actions).
# For local dev: add this to your global ~/.npmrc:
#   //npm.pkg.github.com/:_authToken=<your_personal_access_token>
@shashank519915:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
