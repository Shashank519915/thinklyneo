# Route @shashank519915-scoped packages to GitHub Packages.
# NODE_AUTH_TOKEN must be set in the environment:
# - Vercel: add as an environment variable in project settings
# - CI (GitHub Actions): injected via secrets.PACKAGES_TOKEN
# - Local dev: set in your global ~/.npmrc as a literal token
@shashank519915:registry=https://npm.pkg.github.com
# //npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}
minimum-release-age=0  